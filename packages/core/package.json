{
  "name": "@contact-app/core",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:integration": "vitest run --config ./vitest.integration.config.ts",
    "test:dev": "vitest dev --config ./vitest.integration.config.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx seed/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "env-var": "7.5.0",
    "nanoid": "5.1.9",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "9.7.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "vitest": "3.1.1"
  }
}
