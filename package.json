{
  "name": "contact-app",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "predev": "pnpm run db:up && pnpm i",
    "dev": "turbo dev --ui tui",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test:integration": "turbo test:integration",
    "db:up": "docker compose up -d",
    "db:reset": "docker compose down && rm -rf ./data/postgres && docker compose up -d",
    "db:studio": "pnpm --filter @contact-app/core db:studio",
    "db:push": "pnpm --filter @contact-app/core db:push",
    "db:generate": "pnpm --filter @contact-app/core db:generate",
    "db:migrate": "pnpm --filter @contact-app/core db:migrate",
    "db:seed": "pnpm --filter @contact-app/core db:seed",
    "clean": "turbo clean && rm -rf .turbo && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/node": "25.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.5",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
